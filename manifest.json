{
  "manifest_version": 3,
  "name": "Clay",
  "version": "0.1.0",
  "description": "Connect your browser to Clay.",
  "permissions": [
    "tabs",
    "activeTab",
    "debugger",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.clay.studio/*", "*://localhost:*/*", "*://127.0.0.1:*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
